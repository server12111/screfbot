BOT_TOKEN=your_bot_token_here

# Telegram ID администраторов через запятую
ADMIN_IDS=123456789

# Канал куда приходят заявки на вывод (ID вида -100xxxxxxxxx)
WITHDRAWAL_CHANNEL_ID=-100xxxxxxxxx

# BotoHub токен для проверки подписки на спонсоров
BOTOHUB_TOKEN=your_botohub_token

# BotoHub Views токен для показа рекламы
BOTOHUB_VIEWS_TOKEN=your_botohub_views_token

# Tgrass токен (если пусто — проверка Tgrass пропускается)
TGRASS_TOKEN=
TGRASS_ENDPOINT=https://api.tgrass.io/check

# Путь к базе данных
DATABASE_PATH=data/bot.db
